public class Main {
    public static void main(String[] args) {
        Zoo<Animal> zoo = new Zoo<>();
        List<Mammal> mammals = new ArrayList<>();
        mammals.add(new Mammal("Арслан"));
        List<Bird> birds = new ArrayList<>();
        birds.add(new Bird("Тогоруу"));
        zoo.transferAnimals(mammals, zoo.getAnimals());
        zoo.transferAnimals(birds, zoo.getAnimals());
        // Print names
        List<Animal> animals = zoo.getAnimals();
        for (int i = 0; i < animals.size(); i++) {
            if (i > 0) System.out.print(", ");
            System.out.print(animals.get(i).getName());
        }
    }
}
